{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kimi Cheatsheet",
  "version": "1.1.0",
  "identifier": "com.example.kimi-cheatsheet",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Kimi 命令速查",
        "width": 520,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13"
    }
  }
}
